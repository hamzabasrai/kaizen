{
	"singleQuote": true,
	"trailingComma": "all",
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"printWidth": 120,
	"bracketSpacing": true,
	"arrowParens": "avoid",
	"plugins": ["@trivago/prettier-plugin-sort-imports"],
	"importOrder": ["^react(-native)?$", "<THIRD_PARTY_MODULES>", "^~/(.*)$", "^[./]"],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,
	"importOrderCaseInsensitive": true,
	"endOfLine": "auto"
}
